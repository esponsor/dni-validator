{
  "name": "@esponsor/dni-validator",
  "version": "1.0.0",
  "description": "Validators for Latin American and related national ID documents",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./chile": {
      "types": "./dist/chile/rut.d.ts",
      "import": "./dist/chile/rut.js"
    },
    "./mexico": {
      "types": "./dist/mexico/curp.d.ts",
      "import": "./dist/mexico/curp.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
